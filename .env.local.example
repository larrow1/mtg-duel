# Copy to .env.local and fill in. Do NOT put real keys in this committed example file.
# Get an Anthropic key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# CubeCobra cube ID. Default is the MTGO Vintage Cube.
CUBE_ID=modovintage

# ----- Database (Postgres on Neon) -----
# Pooled connection (used at runtime). From Neon's connection-string panel,
# pick the one with `-pooler` in the host.
DATABASE_URL=

# Unpooled / direct connection (used by Prisma migrate).
# From Neon, the connection string WITHOUT `-pooler`.
DATABASE_URL_UNPOOLED=

# ----- Auth.js (NextAuth v5) -----
# Random 32+ char string. Generate with: `openssl rand -base64 32`
AUTH_SECRET=

# Set to your deployed origin in production (e.g. https://mtg-duel.vercel.app).
# Local dev defaults to http://localhost:3000.
# AUTH_URL=

# ----- Bootstrap admin (used by `npm run seed:admin`, never deployed) -----
ADMIN_EMAIL=
ADMIN_PASSWORD=
